# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...

# Postmark (get from postmarkapp.com → Server → API Tokens)
POSTMARK_SERVER_TOKEN=your-postmark-server-token

# The email address feedback is sent FROM (must be a verified sender in Postmark)
FROM_EMAIL=feedback@yourdomain.com
FROM_NAME=PT Launch Lab

# Make.com webhook for "Passed Submissions → Drive" scenario.
# When PASS is graded, the file is POSTed here and Make uploads it to
# My Drive / ALBACOMANAGEMENT / LEARNER WORK SUBMISSIONS / {Learner Name}/
MAKE_DRIVE_WEBHOOK_URL=https://hook.eu1.make.com/<webhook-id>

# Port (Railway/Render set this automatically)
PORT=3000
